# App
APP_NAME=GaiaGuard
ENV=development

# PostgreSQL (local, no Docker)
# Format: postgresql+psycopg2://username:password@host:port/database_name
DATABASE_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/gaiaguard_db
# Requested example (SQLAlchemy also accepts this format):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gaia_guard

# Alerts (basic: logs to server console; SMS optional via Twilio)
ALERTS_ENABLED=true
ALERT_COOLDOWN_SECONDS=300
# Set true only when Twilio credentials below are valid
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+10000000000
ALERT_TO_NUMBER=+10000000001

# Warn + optional alerts when outside a zone but within radius + this buffer (meters)
NEARBY_ALERT_BUFFER_METERS=800

# Google Earth Engine — register at https://earthengine.google.com/
# After signup: run `earthengine authenticate` OR set GEE_CREDENTIALS_JSON to a service account key.
# Service account must be registered in EE as described in Google docs.
GEE_ENABLED=false
GEE_PROJECT=your-gee-gcp-project-id
# GEE_CREDENTIALS_JSON=C:\path\to\service-account.json
# When true, each POST /update-location runs GEE first and may add/update danger zones (slower).
GEE_AUTO_SYNC_ON_LOCATION=true
GEE_BUFFER_METERS=5000
GEE_LOSS_MEAN_THRESHOLD=0.01
GEE_NDVI_DROP_THRESHOLD=0.2
GEE_ZONE_RADIUS_METERS=1500
# Sentinel-2 windows for NDVI comparison (YYYY-MM-DD)
GEE_BEFORE_START=2022-01-01
GEE_BEFORE_END=2022-06-01
GEE_AFTER_START=2023-01-01
GEE_AFTER_END=2023-06-01
